# Claude worktrees
.claude/worktrees/

# dev CLI
.dev/

# Team pipeline state
.team/

# Beads / Dolt files (added by bd init)
# NOTE: do NOT add a blanket `.beads/` ignore — bd's own .beads/.gitignore
# tracks issues.jsonl + config while ignoring the Dolt runtime. Ignoring all of
# .beads/ breaks bd's JSONL auto-export (its `git add` fails). The credential
# key and *.db files stay ignored via the patterns below.
.dolt/
*.db
.beads-credential-key

# Playwright
.playwright-mcp/

# Phaser demo (docs/) dependencies and lockfile artifacts
docs/node_modules/
docs/package-lock.json

# Jekyll site build artifacts (kept for historical clean-up; safe no-op now)
docs/_site/
docs/.jekyll-cache/
docs/.sass-cache/
docs/.jekyll-metadata
docs/.bundle/
docs/vendor/

# Stray Bundler installs at repo root (gems should go in docs/vendor/bundle/)
/vendor/
