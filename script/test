#!/usr/bin/env bash
set -uo pipefail

PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PROJECT_ROOT"

shopt -s nullglob
SCRIPTS=(tests/*.sh)
shopt -u nullglob

if [ ${#SCRIPTS[@]} -eq 0 ]; then
  echo "No test scripts found under tests/*.sh"
  exit 0
fi

PASSED=()
FAILED=()

for script in "${SCRIPTS[@]}"; do
  echo "=== $script ==="
  if bash "$script"; then
    PASSED+=("$script")
  else
    FAILED+=("$script")
  fi
  echo
done

echo "=============================================================="
echo "  Summary: ${#PASSED[@]} passed, ${#FAILED[@]} failed"
echo "=============================================================="

if [ ${#FAILED[@]} -gt 0 ]; then
  for f in "${FAILED[@]}"; do
    echo "  FAIL  $f"
  done
  exit 1
fi
