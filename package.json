{
  "name": "team",
  "version": "0.5.1",
  "description": "Drive a feature from idea to PR with a team of Claude Code agents.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "test": "bun test",
    "test:evals": "EVALS=1 EVALS_ALL=1 bun test --concurrent --max-concurrency 15 ./tests/*.evals.ts",
    "eval:select": "bun run scripts/eval-select.ts",
    "eval:list": "bun run scripts/eval-list.ts",
    "eval:compare": "bun run scripts/eval-compare.ts"
  },
  "keywords": [
    "automation",
    "cli",
    "claude",
    "ai-agent",
    "devtools"
  ],
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
