{
  "name": "team",
  "version": "0.3.0",
  "description": "Drive a feature from idea to PR with a team of Claude Code agents.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "test": "bun test --ignore 'test/**/*-eval.test.ts' --ignore 'test/**/*-e2e.test.ts'",
    "test:evals": "EVALS=1 bun test --concurrent --max-concurrency 15 'test/**/*-eval.test.ts' 'test/**/*-e2e.test.ts'",
    "test:evals:all": "EVALS_ALL=1 bun run test:evals",
    "test:gate": "EVALS_TIER=gate bun run test:evals",
    "test:periodic": "EVALS_TIER=periodic EVALS_ALL=1 bun run test:evals",
    "eval:select": "bun run scripts/eval-select.ts",
    "eval:list": "bun run scripts/eval-list.ts",
    "eval:compare": "bun run scripts/eval-compare.ts"
  },
  "keywords": [
    "automation",
    "cli",
    "claude",
    "ai-agent",
    "devtools"
  ],
  "devDependencies": {
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1"
  }
}
