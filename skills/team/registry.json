{
  "$comment": "consumes/produces fields are documentation-only; dispatch is driven by the phase table in skills/team/SKILL.md and state.json. Retained to keep the agent inventory and its event vocabulary as reference material.",
  "phases": [
    {"name": "QUESTION", "artifacts": ["task.md", "questions.md", "brief.md"]},
    {"name": "RESEARCH", "artifacts": ["research.md"]},
    {"name": "DESIGN", "artifacts": ["design.md"]},
    {"name": "STRUCTURE", "artifacts": ["structure.md"]},
    {"name": "PLAN", "artifacts": ["plan.md"]},
    {"name": "WORKTREE", "artifacts": []},
    {"name": "IMPLEMENT", "artifacts": []},
    {"name": "PR", "artifacts": []}
  ],
  "agents": [
    {
      "name": "questioner",
      "consumes": "feature.requested",
      "produces": "task.captured"
    },
    {
      "name": "file-finder",
      "consumes": "task.captured",
      "produces": "files.found",
      "parallel": true
    },
    {
      "name": "researcher",
      "consumes": "task.captured",
      "produces": "research.completed",
      "parallel": true
    },
    {
      "name": "design-author",
      "consumes": ["research.completed", "design.revision-requested"],
      "produces": "design.drafted"
    },
    {
      "name": "structure-planner",
      "consumes": ["design.approved", "structure.revision-requested"],
      "produces": "structure.drafted"
    },
    {
      "name": "planner",
      "consumes": "structure.approved",
      "produces": "plan.drafted"
    },
    {
      "name": "test-architect",
      "consumes": "worktree.prepared",
      "produces": "tests.written"
    },
    {
      "name": "implementer",
      "consumes": [
        "tests.confirmed-failing",
        "hard-gate.security-failed",
        "hard-gate.lint-failed",
        "hard-gate.typecheck-failed",
        "hard-gate.build-failed",
        "hard-gate.test-failed",
        "hard-gate.review-failed"
      ],
      "produces": "implementation.completed"
    },
    {
      "name": "code-reviewer",
      "consumes": "implementation.completed",
      "produces": "review.completed",
      "parallel": true
    },
    {
      "name": "security-reviewer",
      "consumes": "implementation.completed",
      "produces": "security-review.completed",
      "parallel": true
    },
    {
      "name": "technical-writer",
      "consumes": "implementation.completed",
      "produces": "docs-review.completed",
      "parallel": true
    },
    {
      "name": "ux-reviewer",
      "consumes": "implementation.completed",
      "produces": "ux-review.completed",
      "parallel": true
    },
    {
      "name": "verifier",
      "consumes": "implementation.completed",
      "produces": "verification.completed",
      "parallel": true
    }
  ],
  "gates": [
    {
      "after": "design.drafted",
      "type": "human",
      "passEvent": "design.approved",
      "failEvent": "design.revision-requested"
    },
    {
      "after": "structure.drafted",
      "type": "human",
      "passEvent": "structure.approved",
      "failEvent": "structure.revision-requested"
    },
    {
      "after": "plan.drafted",
      "type": "router-emit",
      "passEvent": "worktree.prepared",
      "condition": "router prepares isolated git worktree"
    },
    {
      "after": "tests.written",
      "type": "mechanical",
      "condition": "all tests fail with assertion errors, not crashes",
      "passEvent": "tests.confirmed-failing"
    },
    {
      "after": [
        "review.completed",
        "security-review.completed",
        "docs-review.completed",
        "ux-review.completed",
        "verification.completed"
      ],
      "type": "aggregate",
      "hardGates": ["security-review.completed", "verification.completed", "review.completed"],
      "passEvent": "verification.passed",
      "failEvents": {
        "security-review.completed": "hard-gate.security-failed",
        "verification.completed": {
          "format": "hard-gate.lint-failed",
          "lint": "hard-gate.lint-failed",
          "typecheck": "hard-gate.typecheck-failed",
          "build": "hard-gate.build-failed",
          "test": "hard-gate.test-failed"
        },
        "review.completed": "hard-gate.review-failed"
      },
      "maxRetries": 5
    },
    {
      "after": "verification.passed",
      "type": "router-emit",
      "passEvent": "feature.shipped",
      "condition": "router opens PR or commits per user choice"
    }
  ],
  "joins": [
    {
      "wait": ["files.found"],
      "with": "researcher",
      "produces": "research.completed",
      "artifact": "docs/plans/YYYY-MM-DD-<topic>-research.md"
    }
  ]
}
